{
  "name": "@openparachute/hub",
  "version": "0.7.7-rc.1",
  "description": "parachute — the local hub for the Parachute ecosystem (discovery, ports, lifecycle, soon OAuth).",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "parachute": "src/cli.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "src",
    "web/ui/dist",
    "scripts/git-credential-parachute",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ParachuteComputer/parachute-hub.git"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "build:depcheck": "[ ! -f packages/depcheck/package.json ] || [ -f packages/depcheck/dist/index.js ] || bun run --cwd packages/depcheck build",
    "prepare": "bun run build:depcheck",
    "pretest": "bun run build:depcheck",
    "test": "bun test ./src",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "build:spa": "cd web/ui && bun install --frozen-lockfile && bun run build",
    "prepack": "bun run build:spa"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@openparachute/depcheck": "0.1.1",
    "jose": "^6.2.2",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4"
  }
}
